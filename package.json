{
  "name": "pageperf-runner",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "corepack pnpm -r build",
    "dev:api": "corepack pnpm --filter @pageperf-runner/api dev",
    "dev:web": "corepack pnpm --filter @pageperf-runner/web dev",
    "profile:pages": "corepack pnpm --filter @pageperf-runner/api profile:pages",
    "test": "corepack pnpm -r test",
    "lint": "corepack pnpm -r lint"
  }
}
